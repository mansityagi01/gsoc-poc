{
  "name": "yashas_bhat_mcp_testing_workbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n runner,frontend -c cyan,yellow \"npm:dev:runner\" \"npm:dev:frontend\"",
    "dev:runner": "tsx watch runner/src/server/index.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "run:scenarios": "tsx runner/src/server/index.ts --run-once",
    "report": "tsx runner/src/server/index.ts --print-latest",
    "build": "npm run typecheck && vite build --config frontend/vite.config.ts",
    "typecheck": "tsc -p runner/tsconfig.json && tsc -p frontend/tsconfig.app.json",
    "lint": "eslint frontend/src frontend/vite.config.ts runner/src",
    "preview": "vite preview --config frontend/vite.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.12",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "hono": "^4.12.10",
    "lucide-react": "^1.7.0",
    "playwright": "^1.54.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
